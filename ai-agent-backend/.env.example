# Copy to .env and edit. .env is gitignored.

# ---- Postgres ----
POSTGRES_USER=kofon
POSTGRES_PASSWORD=kofon_dev_password
POSTGRES_DB=kofon_chatbot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Composed by app/config.py from the parts above, but you can override here.
# DATABASE_URL=postgresql+asyncpg://kofon:kofon_dev_password@localhost:5432/kofon_chatbot

# ---- App ----
APP_ENV=development
APP_LOG_LEVEL=INFO

# ---- DeepSeek (LLM provider — see memory/project-china-llm-constraint.md) ----
# Get a key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-replace-me
# Cheap model for router / slot-fill / paraphrasing.
DEEPSEEK_CHAT_MODEL=deepseek-chat
# Reasoning model for harder nodes (Phase 3+).
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# ---- Embeddings (Phase 3) ----
# Provider for product / problem text embeddings. One of:
#   hash      — deterministic, non-semantic. Zero-config; CI / smoke-test
#               default. Pipeline works but vector matches will be wrong.
#   bge-m3    — local via `sentence-transformers`. First run downloads
#               ~2 GB; CPU inference is slow on a Pi 4 — pick this only
#               on a real server with ≥ 8 GB RAM.
#   dashscope — Alibaba Qwen `text-embedding-v3`. Hosted, low latency
#               from China, requires DASHSCOPE_API_KEY below.
EMBEDDING_PROVIDER=hash

# Required only when EMBEDDING_PROVIDER=dashscope.
# Get a key at https://dashscope.console.aliyun.com/
# DASHSCOPE_API_KEY=sk-replace-me

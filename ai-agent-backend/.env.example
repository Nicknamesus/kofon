# Copy to .env and edit. .env is gitignored.

# ---- Postgres ----
POSTGRES_USER=kofon
POSTGRES_PASSWORD=kofon_dev_password
POSTGRES_DB=kofon_chatbot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Composed by app/config.py from the parts above, but you can override here.
# DATABASE_URL=postgresql+asyncpg://kofon:kofon_dev_password@localhost:5432/kofon_chatbot

# ---- App ----
APP_ENV=development
APP_LOG_LEVEL=INFO

# ---- DeepSeek (LLM provider — see memory/project-china-llm-constraint.md) ----
# Get a key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-replace-me
# Cheap model for router / slot-fill / paraphrasing.
DEEPSEEK_CHAT_MODEL=deepseek-chat
# Reasoning model for harder nodes (Phase 3+).
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# ---- Embeddings (Phase 3) ----
# Provider for product / problem text embeddings. One of:
#   hash      — deterministic, non-semantic. Zero-config; CI / smoke-test
#               default. Pipeline works but vector matches will be wrong.
#   bge-m3    — local via `sentence-transformers`. First run downloads
#               ~2 GB; CPU inference is slow on a Pi 4 — pick this only
#               on a real server with ≥ 8 GB RAM.
#   dashscope — Alibaba Qwen `text-embedding-v3`. Hosted, low latency
#               from China, requires DASHSCOPE_API_KEY below.
EMBEDDING_PROVIDER=hash

# Required only when EMBEDDING_PROVIDER=dashscope.
# Get a key at https://dashscope.console.aliyun.com/
# DASHSCOPE_API_KEY=sk-replace-me

# ---- Phase 4: CRM (side effects) ----
# CRM provider for outcome_sell / outcome_human / outcome_resolved.
#   log    — default. Writes audit rows to `crm_calls`; never calls a
#            third party. Right choice for demo / CI.
#   zoho   — calls Zoho CRM v6 (Deals, Cases, Tasks). See app/crm/zoho.py.
# Swap by changing this env — no code changes anywhere else.
CRM_PROVIDER=log

# Required only when CRM_PROVIDER=zoho. Create a self-client at
# https://api-console.zoho.com (or accounts.zoho.com.cn for China)
# and exchange the consent code for a refresh token once.
# ZOHO_CLIENT_ID=1000.replace-me
# ZOHO_CLIENT_SECRET=replace-me
# ZOHO_REFRESH_TOKEN=1000.replace-me
# Region: us | eu | in | au | jp | cn. Kofon's primary tenant is in
# China, so this will likely be `cn`.
# ZOHO_REGION=cn
# Optional explicit overrides for sandbox / proxy setups.
# ZOHO_ACCOUNTS_URL=https://accounts.zoho.com.cn
# ZOHO_API_URL=https://www.zohoapis.com.cn

# ---- Phase 4: Email ----
#   log    — default. Writes to `email_calls`; nothing is sent.
#   aliyun — Aliyun DirectMail (China-native transactional email).
MAIL_PROVIDER=log

# Required only when MAIL_PROVIDER=aliyun.
# ALIYUN_ACCESS_KEY_ID=replace-me
# ALIYUN_ACCESS_KEY_SECRET=replace-me
# ALIYUN_DM_REGION=cn-hangzhou
# ALIYUN_DM_ACCOUNT_NAME=noreply@kofon-motion.example
# ALIYUN_DM_FROM_ALIAS=Kofon Chatbot

# Soft-fail = swallow CRM / email errors and still show the user the
# terminal card. The audit rows hold the error so ops can re-drive.
# Set to false once production alerting is wired.
SIDEEFFECTS_SOFT_FAIL=true

# Routing matrix YAML — (main_type, family) → division. Edit divisions
# and inboxes in the file itself; this path is just where the loader
# reads from.
ROUTING_MATRIX_PATH=app/sideeffects/routing.yaml

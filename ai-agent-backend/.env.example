# Copy to .env and edit. .env is gitignored.

# ---- Postgres ----
POSTGRES_USER=kofon
POSTGRES_PASSWORD=kofon_dev_password
POSTGRES_DB=kofon_chatbot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Composed by app/config.py from the parts above, but you can override here.
# DATABASE_URL=postgresql+asyncpg://kofon:kofon_dev_password@localhost:5432/kofon_chatbot

# ---- App ----
APP_ENV=development
APP_LOG_LEVEL=INFO

# ---- DeepSeek (LLM provider — see memory/project-china-llm-constraint.md) ----
# Get a key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-replace-me
# Cheap model for router / slot-fill / paraphrasing.
DEEPSEEK_CHAT_MODEL=deepseek-chat
# Reasoning model for harder nodes (Phase 3+).
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
